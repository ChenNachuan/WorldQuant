# WorldQuant Brain credentials (单账号模式)
WQ_USERNAME=your_email@example.com
WQ_PASSWORD=your_password

# LLM Configuration (choose one)
# Option 1: DeepSeek API (recommended - faster, no local GPU needed)
DEEPSEEK_API_KEY=your_deepseek_api_key

# Option 2: Ollama (local models)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# 通知配置（可选，不配则不发通知）
# 飞书: 群设置 → 机器人 → 添加机器人 → 自定义机器人 → 复制 Webhook 地址
# FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# ===== 飞书机器人指令控制 (feishu_bot.py 使用) =====
# 飞书开放平台 → 应用管理 → 创建应用 → 获取 App ID 和 App Secret
# FEISHU_APP_ID=cli_xxx
# FEISHU_APP_SECRET=xxx
# FEISHU_BOT_PORT=9000

# ===== 团队多账号配置 (run_team_miner.py 使用) =====
# 取消注释并填入凭据，支持 1-10 个账号
# WQ_USERNAME_1=user1@gmail.com
# WQ_PASSWORD_1=password1
# WQ_MEMBER_ID_1=alice

# WQ_USERNAME_2=user2@gmail.com
# WQ_PASSWORD_2=password2
# WQ_MEMBER_ID_2=bob

# WQ_USERNAME_3=user3@gmail.com
# WQ_PASSWORD_3=password3
# WQ_MEMBER_ID_3=charlie

# WQ_USERNAME_4=user4@gmail.com
# WQ_PASSWORD_4=password4
# WQ_MEMBER_ID_4=david
